# 12M CRM - Environment Configuration
# Copy this file to .env and fill in the values

# Database
DATABASE_URL= file:./dev.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/12m_crm

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=24h

# Server
PORT=3000
NODE_ENV=development

# CORS - allowed origins (comma-separated, no wildcard in production)
# Development: CORS_ORIGIN=*
# Production:  CORS_ORIGIN=https://nik12m.com
CORS_ORIGIN=*

# Frontend URL (for dev server proxy)
FRONTEND_URL=http://localhost:5173

# Uploads
UPLOAD_DIR=uploads
UPLOAD_MAX_SIZE=52428800

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
